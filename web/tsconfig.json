{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@neuro-connect/client-core": ["../packages/client-core/src"],
      "@neuro-connect/ui": ["../packages/ui/src"]
    }
  },
  "include": ["src", "capacitor.config.ts"]
}
