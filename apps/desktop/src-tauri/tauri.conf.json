{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Neuro Connect",
  "version": "0.3.0",
  "identifier": "com.yetanotherneuron.neuroconnect",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Neuro Connect",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "publisher": "yetanotherneuron",
    "category": "SocialNetworking",
    "shortDescription": "Lightweight Discord-style chat for communities",
    "longDescription": "Neuro Connect is a portable, self-hosted community chat client with text chat, WebRTC voice, and LAN-ready architecture."
  }
}